root = true

[*.cs]
charset = utf-8-bom
end_of_line = crlf
indent_style = space
indent_size = 4
insert_final_newline = true
dotnet_style_qualification_for_field = false:suggestion
dotnet_diagnostic.CA2007.severity = none

[*.{csproj,props,targets,json,yml,yaml,md}]
indent_style = space
indent_size = 2
insert_final_newline = true
